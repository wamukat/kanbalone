{
  "name": "soloboard",
  "version": "0.9.3",
  "description": "SoloBoard: ultra-light local personal kanban for human and AI collaboration",
  "type": "module",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "pnpm lint:openapi",
    "lint:openapi": "redocly lint docs/openapi.yaml",
    "docs:build": "node scripts/build-pages.mjs",
    "check": "pnpm lint && pnpm test && pnpm build && pnpm docs:build",
    "start": "node dist/src/server.js",
    "test": "node --import tsx --test test/**/*.test.ts",
    "test:e2e": "playwright test",
    "perf:seed": "node scripts/perf-seed.mjs",
    "perf:benchmark": "node scripts/perf-benchmark.mjs"
  },
  "keywords": [
    "soloboard",
    "kanban",
    "fastify",
    "sqlite"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@fastify/static": "^9.1.0",
    "better-sqlite3": "^12.8.0",
    "fastify": "^5.8.4",
    "marked": "^18.0.0",
    "sanitize-html": "^2.17.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@redocly/cli": "^2.26.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.2",
    "@types/sanitize-html": "^2.16.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
